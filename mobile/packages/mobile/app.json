{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.trackup.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1E40AF"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "http://127.0.0.1:8000",
      "router": {},
      "eas": {
        "projectId": "31db1e8f-3a78-4f1f-a1a1-4bd0a3ab17a1"
      }
    },
    "ios": {
      "bundleIdentifier": "com.trackup.mobile",
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#1E40AF"
    },
    "updates": {
      "enabled": false
    },
    "name": "TrackUp",
    "slug": "trackup-mobile",
    "owner": "smi88",
    "version": "1.0.0",
    "scheme": "trackup",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}
